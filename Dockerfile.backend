FROM node:20-slim
WORKDIR /app
RUN apt-get update && apt-get install -y python3 python3-pip make g++ && rm -rf /var/lib/apt/lists/*
RUN pip3 install --break-system-packages scikit-learn numpy
COPY package*.json ./
RUN npm install
COPY server.js .
COPY ml_predict.py .
COPY generate_data.py .
EXPOSE 3000
CMD ["node", "server.js"]